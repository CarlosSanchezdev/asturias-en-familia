{
	"name": "asturias-en-familia-backend",
	"version": "1.0.0",
	"description": "API REST para Asturias en Familia — Cifp Aviles DAW 2025-26",
	"type": "module",
	"main": "src/server.js",
	"scripts": {
		"start": "node src/server.js",
		"dev": "node --watch src/server.js",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --coverage",
		"test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --watch",
		"lint": "eslint src tests"
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^5.0.0",
		"express-validator": "^7.2.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.4.0",
		"morgan": "^1.10.0",
		"multer": "^1.4.5-lts.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.9.0",
		"cross-env": "^10.1.0",
		"eslint": "^9.9.0",
		"jest": "^29.7.0",
		"supertest": "^7.0.0"
	},
	"jest": {
		"testEnvironment": "node",
		"transform": {},
		"moduleNameMapper": {
			"^(\\.{1,2}/.*)\\.js$": "$1"
		},
		"setupFiles": [
			"./tests/setup.js"
		],
		"collectCoverageFrom": [
			"src/**/*.js",
			"!src/server.js"
		]
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
